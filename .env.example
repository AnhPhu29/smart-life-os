# ============================================
# Smart Life OS - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Database ---
DB_USERNAME=smartlife
DB_PASSWORD=smartlife123
DATABASE_URL=mysql://smartlife:smartlife123@localhost:3306/smart_life_os

# --- JWT ---
# Generate a secure key: openssl rand -base64 64
JWT_SECRET=smartlifeossecretkey2024veryverylongsecretkeyforhmacsha256algorithm

# --- Google Cloud / Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- Redis (Optional for Caching) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Email Notifications (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Smart Life OS <noreply@smartlifeos.com>

# --- Telegram Bot Notifications ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- Docker / Production ---
NODE_ENV=development
PORT=8080

